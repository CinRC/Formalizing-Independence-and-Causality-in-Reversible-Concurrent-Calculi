                 | [g ⊢ fs_parr GR2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   let [g ⊢ refp] = unique_diamonds_fb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp])))
  | [g ⊢ fs_nu \a.F1'] ⇒ let [g ⊢ fs_nu \a.F2'] = [g ⊢ F2] in
    let [g ⊢ fs_nu \a.G1'] = [g ⊢ G1] in
    let [g ⊢ fs_nu \a.G2'] = [g ⊢ G2] in
    let [g ⊢ I] = i in
    let [g,a:names ⊢ refp] = unique_diamonds_fb [_ ⊢ F1'] [_ ⊢ F2'] [_ ⊢ G1'] [_ ⊢ G2'] [_ ⊢ I[..]] in [g ⊢ refp]
;


rec unique_diamonds_bb: (g:ctx) {F1:[g ⊢ ccsk.fstep Z1 (kl_base A K[]) X]} {F2:[g ⊢ ccsk.fstep Z2 (kl_base C K[]) X]}
  {G1:[g ⊢ ccsk.fstep Z1 (kl_base B M[]) Y]} {G2:[g ⊢ ccsk.fstep Z2 (kl_base D M[]) Y]} [g ⊢ neq K[] M[]] → [g ⊢ eqp Z1 Z2] =
/ total t1 (unique_diamonds_bb _ _ _ _ _ _ _ _ _ _ _ t1 _ _ _ _) /
mlam F1,F2,G1,G2 ⇒ fn i ⇒ case [_ ⊢ F1] of
  | [g ⊢ fs_pref _] ⇒ let [g ⊢ fs_pref _] = [g ⊢ G1] in (case [g ⊢ F2] of
       | [g ⊢ fs_pref _] ⇒ let [g ⊢ fs_pref _] = [g ⊢ G2] in [g ⊢ refp]
       | [g ⊢ fs_kpref _ DF2] ⇒ impossible irreflexive_neq [g ⊢ DF2])
  | [g ⊢ fs_kpref F1' DF1] ⇒ let [g ⊢ fs_kpref G1' _] = [g ⊢ G1] in (case [g ⊢ F2] of
       | [g ⊢ fs_pref _] ⇒  impossible irreflexive_neq [g ⊢ DF1]
       | [g ⊢ fs_kpref F2' _] ⇒ let [g ⊢ fs_kpref G2' _] = [g ⊢ G2] in
         let [g ⊢ refp] = unique_diamonds_bb [g ⊢ F1'] [g ⊢ F2'] [g ⊢ G1'] [g ⊢ G2'] i in [g ⊢ refp])
  | [g ⊢ fs_suml FL1 DF1] ⇒ (case [g ⊢ F2] of
       | [g ⊢ fs_suml FL2 DF2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_suml GL1 DG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_suml GL2 DG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]
                 | [g ⊢ fs_sumr GR2 DG2] ⇒ impossible target_is_not_std [g ⊢ GR2] [g ⊢ DG1])
            | [g ⊢ fs_sumr GR1 DG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_suml GL2 DG2] ⇒ impossible target_is_not_std [g ⊢ GL2] [g ⊢ DG1]
                 | [g ⊢ fs_sumr GR2 DG2] ⇒ [g ⊢ refp]))
       | [g ⊢ fs_sumr FR2 _] ⇒ impossible target_is_not_std [g ⊢ FR2] [g ⊢ DF1])
  | [g ⊢ fs_sumr FR1 DF1] ⇒ (case [g ⊢ F2] of
       | [g ⊢ fs_suml FL2 _] ⇒ impossible target_is_not_std [g ⊢ FL2] [g ⊢ DF1]
       | [g ⊢ fs_sumr FR2 DF2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_suml GL1 DG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_suml GL2 DG2] ⇒ [g ⊢ refp]
                 | [g ⊢ fs_sumr GR2 DG2] ⇒ impossible target_is_not_std [g ⊢ GR2] [g ⊢ DG1])
            | [g ⊢ fs_sumr GR1 DG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_suml GL2 DG2] ⇒ impossible target_is_not_std [g ⊢ GL2] [g ⊢ DG1]
                 | [g ⊢ fs_sumr GR2 DG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp])))
  | [g ⊢ fs_parl FL1 NF1] ⇒ (case [g ⊢ F2] of
       | [g ⊢ fs_parl FL2 NF2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_parl GL1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1])
            | [g ⊢ fs_parr GR1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ [g ⊢ refp]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]))
       | [g ⊢ fs_parr FR2 NF2] ⇒ impossible key_in_target_of_fstep [g ⊢ FR2] [g ⊢ NF1]
       | [g ⊢ fs_synl FL2 FR2] ⇒ impossible key_in_target_of_fstep [g ⊢ FR2] [g ⊢ NF1]
       | [g ⊢ fs_synr FL2 FR2] ⇒ impossible key_in_target_of_fstep [g ⊢ FR2] [g ⊢ NF1])
  | [g ⊢ fs_parr FR1 NF1] ⇒ (case [g ⊢ F2] of
       | [g ⊢ fs_parl FL2 NF2] ⇒ impossible key_in_target_of_fstep [g ⊢ FL2] [g ⊢ NF1]
       | [g ⊢ fs_parr FR2 NF2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_parl GL1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ [g ⊢ refp]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1])
            | [g ⊢ fs_parr GR1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_parr GR2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in
                   impossible ccsk_unique_fstep [g ⊢ GR1] [g ⊢ GR2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in
                   impossible ccsk_unique_fstep [g ⊢ GR1] [g ⊢ GR2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]))
       | [g ⊢ fs_synl FL2 FR2] ⇒ impossible key_in_target_of_fstep [g ⊢ FL2] [g ⊢ NF1]
       | [g ⊢ fs_synr FL2 FR2] ⇒ impossible key_in_target_of_fstep [g ⊢ FL2] [g ⊢ NF1])
  | [g ⊢ fs_synl FL1 FR1] ⇒ (case [g ⊢ F2] of
       | [g ⊢ fs_parl FL2 NF2] ⇒ impossible key_in_target_of_fstep [g ⊢ FR1] [g ⊢ NF2]
       | [g ⊢ fs_parr FR2 NF2] ⇒ impossible key_in_target_of_fstep [g ⊢ FL1] [g ⊢ NF2]
       | [g ⊢ fs_synl FL2 FR2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_parl GL1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1])
            | [g ⊢ fs_parr GR1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_parr GR2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]))
       | [g ⊢ fs_synr FL2 FR2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_parl GL1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ FL1] [g ⊢ FL2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1])
            | [g ⊢ fs_parr GR1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_parr GR2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in
                   impossible ccsk_unique_fstep [g ⊢ FR1] [g ⊢ FR2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ FL1] [g ⊢ FL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ FL1] [g ⊢ FL2])))
  | [g ⊢ fs_synr FL1 FR1] ⇒ (case [g ⊢ F2] of
       | [g ⊢ fs_parl FL2 NF2] ⇒ impossible key_in_target_of_fstep [g ⊢ FR1] [g ⊢ NF2]
       | [g ⊢ fs_parr FR2 NF2] ⇒ impossible key_in_target_of_fstep [g ⊢ FL1] [g ⊢ NF2]
       | [g ⊢ fs_synl FL2 FR2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_parl GL1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ FL1] [g ⊢ FL2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1])
            | [g ⊢ fs_parr GR1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_parr GR2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in
                   impossible ccsk_unique_fstep [g ⊢ FR1] [g ⊢ FR2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ FL1] [g ⊢ FL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ FL1] [g ⊢ FL2]))
       | [g ⊢ fs_synr FL2 FR2] ⇒ (case [g ⊢ G1] of
            | [g ⊢ fs_parl GL1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR2] [g ⊢ NG1])
            | [g ⊢ fs_parr GR1 NG1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_parr GR2 NG2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synl GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1]
                 | [g ⊢ fs_synr GL2 GR2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL2] [g ⊢ NG1])
            | [g ⊢ fs_synl GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2])
            | [g ⊢ fs_synr GL1 GR1] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_parl GL2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GR1] [g ⊢ NG2]
                 | [g ⊢ fs_parr GR2 NG2] ⇒ impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ NG2]
                 | [g ⊢ fs_synl GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   impossible ccsk_unique_fstep [g ⊢ GL1] [g ⊢ GL2]
                 | [g ⊢ fs_synr GL2 GR2] ⇒
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in
                   let [g ⊢ refp] = unique_diamonds_bb [g ⊢ FR1] [g ⊢ FR2] [g ⊢ GR1] [g ⊢ GR2] i in [g ⊢ refp])))
  | [g ⊢ fs_nu \a.F1'] ⇒ let [g ⊢ fs_nu \a.F2'] = [g ⊢ F2] in
    let [g ⊢ fs_nu \a.G1'] = [g ⊢ G1] in
    let [g ⊢ fs_nu \a.G2'] = [g ⊢ G2] in
    let [g ⊢ I] = i in
    let [g,a:names ⊢ refp] = unique_diamonds_bb [_ ⊢ F1'] [_ ⊢ F2'] [_ ⊢ G1'] [_ ⊢ G2'] [_ ⊢ I[..]] in [g ⊢ refp]
;

rec unique_diamonds: (g:ctx) {T1:[g ⊢ ccsk.step X (kl_base A K[]) Z1]} {T2:[g ⊢ ccsk.step X (kl_base C K[]) Z2]}
  {U1:[g ⊢ ccsk.step Y (kl_base B M[]) Z1]} {U2:[g ⊢ ccsk.step Y (kl_base D M[]) Z2]}
  [g ⊢ ccsk_same_direction T1 T2] → [g ⊢ ccsk_same_direction U1 U2] → [g ⊢ neq K[] M[]] → [g ⊢ eqp Z1 Z2] =
/ total (unique_diamonds) /
mlam T1,T2,U1,U2 ⇒ fn sdt,sdu,i ⇒ case sdt of
  | [g ⊢ ccsk_sdf]:[g ⊢ ccsk_same_direction (fw FT1) (fw FT2)] ⇒ (case sdu of
       | [g ⊢ ccsk_sdf]:[g ⊢ ccsk_same_direction (fw FU1) (fw FU2)] ⇒ 
         unique_diamonds_ff [g ⊢ FT1] [g ⊢ FT2] [g ⊢ FU1] [g ⊢ FU2] i
       | [g ⊢ ccsk_sdb]:[g ⊢ ccsk_same_direction (bw BU1) (bw BU2)] ⇒
         let [g ⊢ FU1] = ccsk_loop_lemma_two [g ⊢ BU1] in
         let [g ⊢ FU2] = ccsk_loop_lemma_two [g ⊢ BU2] in
         unique_diamonds_fb [g ⊢ FT1] [g ⊢ FT2] [g ⊢ FU1] [g ⊢ FU2] i)
  | [g ⊢ ccsk_sdb]:[g ⊢ ccsk_same_direction (bw BT1) (bw BT2)] ⇒ (case sdu of
       | [g ⊢ ccsk_sdf]:[g ⊢ ccsk_same_direction (fw FU1) (fw FU2)] ⇒
         let [g ⊢ FT1] = ccsk_loop_lemma_two [g ⊢ BT1] in
         let [g ⊢ FT2] = ccsk_loop_lemma_two [g ⊢ BT2] in
         unique_diamonds_fb [g ⊢ FU1] [g ⊢ FU2] [g ⊢ FT1] [g ⊢ FT2] (symmetric_neq i)
       | [g ⊢ ccsk_sdb]:[g ⊢ ccsk_same_direction (bw BU1) (bw BU2)] ⇒
         let [g ⊢ FT1] = ccsk_loop_lemma_two [g ⊢ BT1] in
         let [g ⊢ FT2] = ccsk_loop_lemma_two [g ⊢ BT2] in
         let [g ⊢ FU1] = ccsk_loop_lemma_two [g ⊢ BU1] in
         let [g ⊢ FU2] = ccsk_loop_lemma_two [g ⊢ BU2] in
         unique_diamonds_bb [g ⊢ FT1] [g ⊢ FT2] [g ⊢ FU1] [g ⊢ FU2] i)
;


% Base case of the definition of equivalence of CCSK transitions
LF ccsk_equiv_tr_base: ccsk.step P KL Q → ccsk.step R KL S → type =
  | ccsk_etb: ccsk_same_direction (T:ccsk.step P KL1 Q) (T':ccsk.step R KL1 S) 
            → ccsk_same_direction (U:ccsk.step P KL2 R) (U':ccsk.step Q KL2 S)
            → ccsk_indep_tr T U → ccsk_equiv_tr_base T T'
;

% Equivalence of CCSK transitions ~:
% Reflexive, symmetric and transitive closure of the ccsk_equiv_tr_base relation.
LF ccsk_equiv_tr: ccsk.step P KL1 Q → ccsk.step R KL2 S → type =
  | ccsk_et_base: ccsk_equiv_tr_base T T' → ccsk_equiv_tr T T'
  | ccsk_et_refl: ccsk_equiv_tr T T
  | ccsk_et_sym: ccsk_equiv_tr T' T → ccsk_equiv_tr T T'
  | ccsk_et_trans: ccsk_equiv_tr T T' → ccsk_equiv_tr T' T'' → ccsk_equiv_tr T T''
;

% Equivalent CCSK transitions share the same keyed label
rec ccsk_equiv_tr_have_same_label: (g:ctx) (T:[g ⊢ ccsk.step P KL1 Q]) (T':[g ⊢ ccsk.step R KL2 S]) 
  [g ⊢ ccsk_equiv_tr T T'] → [g ⊢ eqkl KL1 KL2] =
/ total e (ccsk_equiv_tr_have_same_label _ _ _ _ _ _ _ _ _ e) /
fn e ⇒ case e of
  | [_ ⊢ ccsk_et_base _] ⇒ [_ ⊢ refkl]
  | [_ ⊢ ccsk_et_refl] ⇒ [_ ⊢ refkl]
  | [_ ⊢ ccsk_et_sym E'] ⇒ let [_ ⊢ refkl] = ccsk_equiv_tr_have_same_label [_ ⊢ E'] in [_ ⊢ refkl]
  | [_ ⊢ ccsk_et_trans E1 E2] ⇒ let [_ ⊢ refkl] = ccsk_equiv_tr_have_same_label [_ ⊢ E1] in
                                 let [_ ⊢ refkl] = ccsk_equiv_tr_have_same_label [_ ⊢ E2] in [_ ⊢ refkl]
;

% If two CCSK transitions are equivalent, then their enriched versions are equivalent
rec enrich_preserves_equiv_tr: (g:ctx) {T:[g ⊢ ccsk.step X KL1 Y]} {T':[g ⊢ ccsk.step Z KL2 W]}
  (T+:[g ⊢ ccskp.step X T1 Y]) (T'+:[g ⊢ ccskp.step Z T1' W]) [g ⊢ ccsk_equiv_tr T T']
  → [g ⊢ enrich T T+] → [g ⊢ enrich T' T'+] → [g ⊢ equiv_tr T+ T'+] =
/ total e (enrich_preserves_equiv_tr _ _ _ _ _ _ _ _ _ _ _ _ _ e _ _) /
mlam T,T' ⇒ fn e,ent,ent' ⇒ case e of
  | [g ⊢ ccsk_et_base (ccsk_etb SDT SDU I)] ⇒
    % We apply the auxiliary lemma sdir_ccsk_to_ccskp to infer that T+ and T'+ have same direction
    let [g ⊢ SDT+]:[g ⊢ same_direction T+ T'+] = sdir_ccsk_to_ccskp [g ⊢ SDT] ent ent' in
    % We apply the enrich function to U and U', obtaining U+ and U'+
    let [g ⊢ SDU]:[g ⊢ ccsk_same_direction U U'] = [g ⊢ SDU] in
    let [g ⊢ ex_en ENU] = total_enrich [g ⊢ U] in
    let [g ⊢ ex_en ENU'] = total_enrich [g ⊢ U'] in
    % We apply the auxiliary lemma sdir_ccsk_to_ccskp to infer that U+ and U'+ have same direction
    let [g ⊢ SDU+]:[g ⊢ same_direction U+ U'+] = sdir_ccsk_to_ccskp [g ⊢ SDU] [g ⊢ ENU] [g ⊢ ENU'] in
    % Inversion on I:ccsk_indep_tr T U to obtain I+, witness that the proof labels used by T+ and U+ are independent.
    % This collaterally creates two spurious copies of T+ and U+, that we unify by functionality of enrich
    let [g ⊢ ccsk_ind_tr ENT'' ENU'' I+ _] = [g ⊢ I] in
    let [g ⊢ refst] = functional_enrich ent [g ⊢ ENT''] in
    let [g ⊢ refst] = functional_enrich [g ⊢ ENU] [g ⊢ ENU''] in
    % We cannot yet say that T+ and T'+ are equivalent because we do not know yet that their proof labels are equal:
    % The instructions below have the goal of proving this equality.
    % Square lemma on T+,U+, to obtain a second pair of transitions U''+,T''+ closing the square.
    % Such transitions have the same proof labels as T+,U+. We want to prove that U''+,T''+ coincide with U'+ and T'+
    let [g ⊢ sq U''+ T''+ SDT'+ SDU'+] = sp [g ⊢ T+] [g ⊢ U+] [g ⊢ ind_tr I+ (ct _ _ (st_s* U+))] in
    % Map from ccskp to ccsk to forget U''+,T''+,T+ and U+. We denote U'',T'' the "forgotten" versions of the first two
    let {FGT'':[g ⊢ forget T''+ T'']}[g ⊢ ex_fg FGT''] = total_forget [g ⊢ T''+] in
    let {FGU'':[g ⊢ forget U''+ U'']}[g ⊢ ex_fg FGU''] = total_forget [g ⊢ U''+] in
    let [g ⊢ ex_fg FGT] = total_forget [g ⊢ T+] in
    let [g ⊢ ex_fg FGU] = total_forget [g ⊢ U+] in
    % Bijection between ccsk and ccskp, to infer that forget(enrich(T))=T and forget(enrich(U))=U
    let [g ⊢ refs] = inverse_two ent [g ⊢ FGT] in
    let [g ⊢ refs] = inverse_two [g ⊢ ENU] [g ⊢ FGU] in
    % We apply the auxiliary lemma injective_forget_on_labels to infer that T and T'' have the same keys. Same for U and U''
    let [g ⊢ refkl] = injective_forget_on_labels [g ⊢ FGT] [g ⊢ FGT''] in
    let [g ⊢ refkl] = injective_forget_on_labels [g ⊢ FGU] [g ⊢ FGU''] in
    % We apply the auxiliary lemma sdir_ccskp_to_ccsk to infer that T and T'' have same direction. Same for U and U''
    let [g ⊢ SDU'] = sdir_ccskp_to_ccsk [g ⊢ SDU'+] [g ⊢ FGU] [g ⊢ FGU''] in
    let [g ⊢ SDT'] = sdir_ccskp_to_ccsk [g ⊢ SDT'+] [g ⊢ FGT] [g ⊢ FGT''] in
    % We denote as K and M the keys of T and U respectively; for decidability of keys, they are either equal or different
    let [g ⊢ T]:[g ⊢ ccsk.step _ (kl_base _ K[]) _] = [g ⊢ T] in
    let [g ⊢ U]:[g ⊢ ccsk.step _ (kl_base _ M[]) _] = [g ⊢ U] in
    (case dec_eq_keys [g] [⊢ K] [⊢ M] of
       % If K = M, we have a contradiction (forward composable transitions with same key)
       | [g ⊢ c_eq] ⇒ (case [g ⊢ SDT] of
            | [g ⊢ ccsk_sdf]:[g ⊢ ccsk_same_direction (fw FT) (fw FT')] ⇒ (case [g ⊢ SDU] of
                 | [g ⊢ ccsk_sdf]:[g ⊢ ccsk_same_direction (fw FU) (fw FU')] ⇒
                   impossible ccsk_no_composable_fw_tr_with_same_key [g ⊢ FT] [g ⊢ FU']
                 | [g ⊢ ccsk_sdb]:[g ⊢ ccsk_same_direction (bw BU) (bw BU')] ⇒
                   impossible ccsk_no_composable_fw_tr_with_same_key (ccsk_loop_lemma_two [g ⊢ BU]) [g ⊢ FT])
            | [g ⊢ ccsk_sdb]:[g ⊢ ccsk_same_direction (bw BT) (bw BT')] ⇒ (case [g ⊢ SDU] of
                 | [g ⊢ ccsk_sdf]:[g ⊢ ccsk_same_direction (fw FU) (fw FU')] ⇒
                   impossible ccsk_no_composable_fw_tr_with_same_key (ccsk_loop_lemma_two [g ⊢ BT]) [g ⊢ FU]
                 | [g ⊢ ccsk_sdb]:[g ⊢ ccsk_same_direction (bw BU) (bw BU')] ⇒
                   impossible ccsk_no_composable_fw_tr_with_same_key (ccsk_loop_lemma_two [g ⊢ BU']) (ccsk_loop_lemma_two [g ⊢ BT])))
       % If K != M, we can apply the auxiliary lemma unique_diamonds to prove that (T',T'') and (U',U'') coincide
       | [g ⊢ c_neq N] ⇒ let [g ⊢ refp] = unique_diamonds [g ⊢ T'] [g ⊢ T''] [g ⊢ U'] [g ⊢ U''] 
           (ccsk_same_direction_trans (ccsk_same_direction_sym [g ⊢ SDT]) [g ⊢ SDT'])
           (ccsk_same_direction_trans (ccsk_same_direction_sym [g ⊢ SDU]) [g ⊢ SDU']) [g ⊢ N] in
         % As a consequence, (T'+,T''+) and (U'+,U''+) also coincide
         let [g ⊢ refst] = unique_step [g ⊢ T'+] [g ⊢ T''+] in
         let [g ⊢ refst] = unique_step [g ⊢ U'+] [g ⊢ U''+] in
         % We can finally say that T+ and T'+ are equivalent
         [g ⊢ et_base (etb SDT+ SDU+ (ind_tr I+ (ct T+ U+ (st_s* U+))))])
  | [g ⊢ ccsk_et_refl] ⇒ let [g ⊢ refst] = functional_enrich ent ent' in [g ⊢ et_refl]
  | [g ⊢ ccsk_et_sym E] ⇒ let [g ⊢ E'] = enrich_preserves_equiv_tr [g ⊢ T'] [g ⊢ T] [g ⊢ E] ent' ent in [g ⊢ et_sym E']
  | [g ⊢ ccsk_et_trans E1 E2] ⇒ let [g ⊢ E1]:[g ⊢ ccsk_equiv_tr T T''] = [g ⊢ E1] in
    let [g ⊢ ex_en ENT''] = total_enrich [g ⊢ T''] in
    let [g ⊢ E1'] = enrich_preserves_equiv_tr [g ⊢ T] [g ⊢ T''] [g ⊢ E1] ent [g ⊢ ENT''] in
    let [g ⊢ E2'] = enrich_preserves_equiv_tr [g ⊢ T''] [g ⊢ T'] [g ⊢ E2] [g ⊢ ENT''] ent' in [g ⊢ et_trans E1' E2']
;

% Propagation of coinitial independence (PCI):
% Given t:step X KL1 Y, u:step X KL2 Z, u':step Y KL2 W and t':step Z KL1 W,
% where (t,t') and (u,u') have same direction,
% if t and u are independent, then u' and inv_tr(t) are independent.
rec ccsk_pci: (g:ctx) (T:[g ⊢ ccsk.step X KL1 Y]) (U:[g ⊢ ccsk.step X KL2 Z])
  (U':[g ⊢ ccsk.step Y KL2 W]) (T':[g ⊢ ccsk.step Z KL1 W]) (RT:[g ⊢ ccsk.step Y KL1 X])
  [g ⊢ ccsk_same_direction T T'] → [g ⊢ ccsk_same_direction U U'] → [g ⊢ ccsk_indep_tr T U] → 
  [g ⊢ ccsk_inv_tr T RT] → [g ⊢ ccsk_indep_tr U' RT] =
/ total (ccsk_pci _ _ _ _ _ _ _ t _ _ _ _ _ _) /
fn sdt,sdu,i,hr ⇒
% Inversion on i: ENT and ENU map t and u to their enriched versions t+ and u+; I denotes independence of t+ and u+
let [g ⊢ ccsk_ind_tr ENT ENU I _] = i in
% t,u,u' and t' are not explicit parameters of the function ccsk_pci.
% We give an explicit annotation of the types of sdt and sdu, to obtain explicit names T,U,U' and T'
let [g ⊢ SDT]:[g ⊢ ccsk_same_direction T T'] = sdt in
let [g ⊢ SDU]:[g ⊢ ccsk_same_direction U U'] = sdu in
% We apply the enrich map from ccsk to ccskp to obtain U'+, enriched transitions of U'
let {ENU':[g ⊢ enrich U' U'+]}[g ⊢ ex_en ENU'] = total_enrich [g ⊢ U'] in
% Inversion on hr to obtain RT, the reverse transition of T
let [g ⊢ ccsk_it T RT] = hr in
% Map from ccsk to ccskp to enrich RT
let {ENRT:[g ⊢ enrich RT RT+]}[g ⊢ ex_en ENRT] = total_enrich [g ⊢ RT] in
% Auxiliary lemmas to infer that RT+, the enriched transition of the reverse transition of T, is the reverse of the enriched transition of T
let [g ⊢ HR+]:[g ⊢ inv_tr T+ RT+] = inv_ccsk_to_ccskp hr [g ⊢ ENT] [g ⊢ ENRT] in
let [g ⊢ it T+ RT+] = [g ⊢ HR+] in
% Since T+ and U+ are independent, U+ and T+ are also independent (symmetry of independence)
let [g ⊢ I'] = symmetric_indep_pl [g ⊢ I] in
% Since U and U' are equivalent, U+ and U'+ are also equivalent
let [g ⊢ EU+] = enrich_preserves_equiv_tr [g ⊢ U] [g ⊢ U']
    [g ⊢ ccsk_et_base (ccsk_etb SDU SDT (ccsk_ind_tr ENU ENT I' (ctr _ _ (ccsk.st_s* T))))] [g ⊢ ENU] [g ⊢ ENU'] in
% Since U+ and U'+ are equivalent, they have the same proof label
let [g ⊢ refpl] = equiv_tr_have_same_label [g ⊢ EU+] in
% We conclude by observing that U' and RT are independent, since the proof labels of their enriched versions are independent
[g ⊢ ccsk_ind_tr ENU' ENRT I' (ctr _ _ (ccsk.st_s* RT))]
;


% Proof that step is symmetric
rec ccsk_symmetric_step: (g:ctx) [g ⊢ ccsk.step X KL Y] → [g ⊢ ccsk.step Y KL X] =
/ total s (ccsk_symmetric_step _ _ _ s) /
fn s ⇒ case s of
    | [g ⊢ fw F] ⇒ let [g ⊢ B] = ccsk_loop_lemma_one [g ⊢ F] in [g ⊢ bw B]
    | [g ⊢ bw B] ⇒ let [g ⊢ F] = ccsk_loop_lemma_two [g ⊢ B] in [g ⊢ fw F]
;

% Proof that step* is symmetric
rec ccsk_symmetric_step*: (g:ctx) [g ⊢ ccsk.step* X Y] → [g ⊢ ccsk.step* Y X] =
/ total s (ccsk_symmetric_step* _ _ _ s) /
fn s ⇒ case s of
  | [g ⊢ ccsk.id_s*] ⇒ [g ⊢ ccsk.id_s*]
  | [g ⊢ ccsk.st_s* S] ⇒ let [g ⊢ S'] = ccsk_symmetric_step [g ⊢ S] in [g ⊢ ccsk.st_s* S']
  | [g ⊢ ccsk.tr_s* S1* S2*] ⇒ let [g ⊢ S1*'] = ccsk_symmetric_step* [g ⊢ S1*] in
       let [g ⊢ S2*'] = ccsk_symmetric_step* [g ⊢ S2*] in [g ⊢ ccsk.tr_s* S2*' S1*']
;

% Equivalent transitions are connected
rec ccsk_equiv_tr_are_connected: (g:ctx) (T:[g ⊢ ccsk.step P A Q]) (T':[g ⊢ ccsk.step R B S])
  [g ⊢ ccsk_equiv_tr T T'] → [g ⊢ ccsk.conn_tr T T'] =
/ total e (ccsk_equiv_tr_are_connected _ _ _ _ _ _ _ _ _ e) /
fn e ⇒ case e of
  | [_ ⊢ ccsk_et_base (ccsk_etb _ SD2 _)]:[_ ⊢ ccsk_equiv_tr T T'] ⇒
    let [_ ⊢ _]:[_ ⊢ ccsk_same_direction U _] = [_ ⊢ SD2] in
    [_ ⊢ ctr T T' (ccsk.tr_s* (ccsk.st_s* U) (ccsk.st_s* T'))]
  | [_ ⊢ ccsk_et_refl] ⇒ let [_ ⊢ _]:[_ ⊢ ccsk_equiv_tr T T] = e in [_ ⊢ ctr _ _ (ccsk.st_s* T)]
  | [_ ⊢ ccsk_et_sym E'] ⇒ let [g ⊢ ctr T' T S*] = ccsk_equiv_tr_are_connected [_ ⊢ E'] in
                 let [g ⊢ S*'] = ccsk_symmetric_step* [g ⊢ S*] in [g ⊢ ctr _ _ (ccsk.tr_s* (ccsk.st_s* T) (ccsk.tr_s* S*' (ccsk.st_s* T')))]
  | [_ ⊢ ccsk_et_trans E1 E2] ⇒ let [g ⊢ ctr _ T S1*] = ccsk_equiv_tr_are_connected [_ ⊢ E1] in
                      let [g ⊢ ctr _ _ S2*] = ccsk_equiv_tr_are_connected [_ ⊢ E2] in
                      let [g ⊢ RT] = ccsk_symmetric_step [g ⊢ T] in [g ⊢ ctr _ _ (ccsk.tr_s* S1* (ccsk.tr_s* (ccsk.st_s* RT) S2*))]
;

% Independence respects events (IRE):
% Given three transitions t,t' and u, if t~t' (t and t' are equivalent) and t' and u are independent,
% then also t and u are independent.
rec ccsk_ire: (g:ctx) {T:[g ⊢ ccsk.step X1 KL1 Y1]} {T':[g ⊢ ccsk.step X2 KL2 Y2]} {U:[g ⊢ ccsk.step X3 KL3 Y3]} 
  [g ⊢ ccsk_equiv_tr T T'] → [g ⊢ ccsk_indep_tr T' U] → [g ⊢ ccsk_indep_tr T U] =
/ total e (ccsk_ire _ _ _ _ _ _ _ _ _ _ _ _ _ e _) /
mlam T,T',U ⇒ fn e,i ⇒ let [g ⊢ ccsk_ind_tr ENT' ENU I (ctr _ _ S'*)] = i in
let {ENT:[g ⊢ enrich T T+]}[g ⊢ ex_en ENT] = total_enrich [g ⊢ T] in
let [_ ⊢ refkl] = ccsk_equiv_tr_have_same_label e in
let [g ⊢ E+] = enrich_preserves_equiv_tr [g ⊢ T] [g ⊢ T'] e [g ⊢ ENT] [g ⊢ ENT'] in
let [_ ⊢ refpl] = equiv_tr_have_same_label [g ⊢ E+] in
let [g ⊢ ctr _ _ S*] = ccsk_equiv_tr_are_connected e in
let [g ⊢ RT'] = ccsk_symmetric_step [g ⊢ T'] in [_ ⊢ ccsk_ind_tr ENT ENU I (ctr _ _ (ccsk.tr_s* S* (ccsk.tr_s* (ccsk.st_s* RT') S'*)))]
;